{
  "name": "symboltracker-client",
  "version": "1.0.2",
  "description": "SymbolTracker desktop overlay for WoW raid coordination",
  "author": "smrizzo",
  "repository": {
    "type": "git",
    "url": "https://github.com/smrizzo/Symbol-Tracker.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.1.7",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.symboltracker.app",
    "productName": "SymbolTracker",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "smrizzo",
      "repo": "Symbol-Tracker",
      "releaseType": "release"
    },
    "files": [
      "**/*",
      "../assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    }
  }
}
