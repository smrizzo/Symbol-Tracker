{
  "name": "symboltracker-client",
  "version": "1.0.0",
  "description": "SymbolTracker desktop overlay for WoW raid coordination",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.symboltracker.app",
    "productName": "SymbolTracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "../assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    }
  }
}
